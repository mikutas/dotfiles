{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>aquaproj/aqua-renovate-config#2.12.1",
    "github>aquaproj/aqua-renovate-config:installer-script#2.12.1(aliases\\..*sh)",
    "github>mikutas/my-renovate-config"
  ],
  "packageRules": [],
  "recreateWhen": "always",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/aliases\\..*sh/"
      ],
      "matchStrings": [
        "renovate\\/renovate:(?<currentValue>.*?) sh"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "renovate/renovate"
    }
  ]
}
